    local header = "["..tanggal.."]\n["..jam.."]\n["..angkaAcak.."]\nHANZ\nGAME:TOWNSHIP"

    local menu = gg.choice({
        "1. MEGA PLANE",
        "2. SUPER SONIC DRAGON",
        "3. LAUNCH VEHICLE",
        "4. ROCK PLANE",
        "5. A-LISTER JET",
        "6. ECLAIR PLANE",
        "7. LUCK JET",
        "8. STEALTH AIRCAFT",
        "9. ARABIAN PLANE",
        "10. FASHION PLANE",
        "11. TROPICAL PLANE",
        "12. KELUAR"

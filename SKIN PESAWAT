    if menu == 1 then MENU_1()
    elseif menu == 2 then MENU_2()
    elseif menu == 3 then MENU_3()
    elseif menu == 4 then MENU_4()
    elseif menu == 5 then MENU_5()
    elseif menu == 6 then MENU_6()
    elseif menu == 7 then MENU_7()
    elseif menu == 8 then MENU_8()
    elseif menu == 9 then MENU_9()
    elseif menu == 10 then MENU_10()
    elseif menu == 11 then MENU_11()
    elseif menu == 12 then ExitEffect() end
    
    gg.clearResults() 
end


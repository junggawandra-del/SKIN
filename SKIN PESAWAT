-- HANZ LOADER - TOWNSHIP EDITION
-- STATUS: 100% LOGIKA TERPISAH PER MENU

local function LoadingEffect(msg, duration)
    local frames = {"┏", "┳", "┓", "┣", "╋", "┫", "┗", "┻", "┛"}
    for i = 1, duration do
        for _, frame in ipairs(frames) do
            gg.toast(frame .. " " .. msg .. " " .. frame)
            gg.sleep(50)
        end
    end
end

local function ExitEffect()
    local bars = {"█▒▒▒▒▒▒▒▒▒", "███▒▒▒▒▒▒▒", "█████▒▒▒▒▒", "███████▒▒▒", "██████████"}
    for _, bar in ipairs(bars) do
        gg.toast("EXITING: " .. bar)
        gg.sleep(200)
    end
    print("HANZ SCRIPT CLOSED")
    os.exit()
end


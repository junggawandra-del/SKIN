-- MENU UTAMA
function HOME()
  menu = gg.choice({
    "1. AERIAL PORTAL",
    "2. FESTIVAL AIRPORT",
    "3. TROPICAL AIRPORT",
    "4. SPACEPORT",
    "5. ROCK AIRPORT",
    "6. CINEMA AIRPORT",
    "7. EASTER AIRPORT",
    "8. SUGARY AIRPORT", 
    "9. LUCK AIRPORT",
    "10. SECRET BASE",
    "11. FASHION AIRPORT",
    "12. ARABIAN AIRPORT",
    "13. NEXT UPDATE",
    "14. KELUAR"
  }, nil, "AIRPORT SKIN MENU")

  if menu == 1 then 
    AERIAL_PORTAL_LOGIC() 
  elseif menu == 2 then 
    FESTIVAL_AIRPORT_LOGIC()
  elseif menu == 3 then 
    TROPICAL_AIRPORT_LOGIC()
  elseif menu == 4 then 
    SPACEPORT_LOGIC() 
  elseif menu == 5 then 
    ROCK_AIRPORT_LOGIC()
  elseif menu == 6 then 
    CINEMA_AIRPORT_LOGIC()
  elseif menu == 7 then 
    EASTER_AIRPORT_LOGIC()
  elseif menu == 8 then 
    SUGARY_AIRPORT_LOGIC() 
  elseif menu == 9 then 
    LUCK_AIRPORT_LOGIC()
  elseif menu == 10 then 
    SECRET_BASE_LOGIC()
  elseif menu == 11 then 
    FASHION_AIRPORT_LOGIC()
  elseif menu == 12 then 
    ARABIAN_AIRPORT_LOGIC()
  elseif menu == 13 then
    gg.alert("Menu ini akan di update secara bertahap")
  elseif menu == 14 then
    os.exit()
  end
  X = -1
end


-- LOGIKA AERIAL PORTAL
function AERIAL_PORTAL_LOGIC()
    gg.clearResults()
    local items = gg.getListItems()
    local updateList = {}

    if #items == 0 then
        gg.alert("⚠️ Saved List kosong!\nPastikan data sudah disimpan di daftar dengan nama 'HANZ DATA 1' dst.")
        return
    end

    for i, v in ipairs(items) do
        if v.name == "HANZ DATA 1" then
            v.value = 0x696B5320
            v.freeze = true
        elseif v.name == "HANZ DATA 2" then
            v.value = 0x69415F6E
            v.freeze = true
        elseif v.name == "HANZ DATA 3" then
            v.value = 0x726F7072
            v.freeze = true
        elseif v.name == "HANZ DATA 4" then
            v.value = 0x50535F74
            v.freeze = true
        elseif v.name == "HANZ DATA 5" then
            v.value = 0x00000033
            v.freeze = true
        elseif v.name == "HANZ DATA 6" then
            v.value = 0x00000000
            v.freeze = true
        elseif v.name == "HANZ NILAI POINTER" then
            v.value = 0
            v.freeze = true
        elseif v.name == "HANZ NILAI" then
            v.value = 2
            v.freeze = true
        end

        if v.freeze then
            table.insert(updateList, v)
        end
    end

    if #updateList > 0 then
        gg.setValues(updateList)
        gg.addListItems(updateList)
        gg.toast("✅ Aerial Portal: " .. #updateList .. " data berhasil diubah!")
    else
        gg.toast("⚠️ Tidak ditemukan nama 'HANZ DATA' yang cocok.")
    end
end

